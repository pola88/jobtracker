generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InterviewStatus {
  applied
  screening
  tech
  offer
  rejected
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  interviews   Interview[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Interview {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  position  String
  recruiter String?
  date      DateTime
  salary    Decimal?        @db.Decimal(10, 2)
  benefits  String?
  status    InterviewStatus @default(applied)
  tags      String[]        @default([])
  notes     InterviewNote[]
  steps     InterviewStep[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model InterviewNote {
  id          String     @id @default(cuid())
  interviewId String
  interview   Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime   @default(now())
}

model InterviewStep {
  id            String     @id @default(cuid())
  interviewId   String
  interview     Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  title         String
  type          String
  scheduledAt   DateTime?
  completedAt   DateTime?
  outcome       String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

