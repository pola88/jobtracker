generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InterviewStatus {
  active
  stand_by
  not_interested
  rejected
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String
  interviews      Interview[]
  businessProfile BusinessProfile?
  invoices        Invoice[]
  clients         Client[]
  invoiceLineItems InvoiceLineItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Interview {
  id                String          @id @default(cuid())
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company           String
  position          String
  recruiter         String?
  date              DateTime
  benefits          String?
  compensationType  CompensationType @default(fixed)
  compensationLower Decimal?        @db.Decimal(12, 2)
  compensationUpper Decimal?        @db.Decimal(12, 2)
  compensationNotes String?
  currency          String?         @default("USD")
  experienceRating  ExperienceRating @default(neutral)
  status            InterviewStatus @default(active)
  notes             InterviewNote[]
  steps             InterviewStep[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model InterviewNote {
  id          String     @id @default(cuid())
  interviewId String
  interview   Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime   @default(now())
}

model InterviewStep {
  id            String     @id @default(cuid())
  interviewId   String
  interview     Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  title         String
  type          String
  scheduledAt   DateTime?
  completedAt   DateTime?
  outcome       String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum CompensationType {
  fixed
  hourly
}

enum ExperienceRating {
  very_negative
  negative
  neutral
  positive
  very_positive
}

model BusinessProfile {
  id              String    @id @default(cuid())
  // Personal/Company Info
  firstName       String?
  lastName        String?
  companyName     String?
  email           String
  website         String?
  phoneNumber     String?
  isOrganization  Boolean   @default(false)
  
  // Address
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  postalCode      String
  country         String    @default("US")
  
  // Relations
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Client {
  id              String    @id @default(cuid())
  // Company/Client Info
  name            String    
  email           String?
  website         String?
  phoneNumber     String?
  contactPerson   String?  
  
  // Address
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  country         String?   @default("US")
  
  // Notes
  notes           String?
  
  // Relations
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id            String          @id @default(cuid())
  invoiceNumber String          @unique
  invoiceDate   DateTime
  dueDate       DateTime
  status        InvoiceStatus   @default(draft)
  
  // Financial
  subtotal      Decimal         @db.Decimal(12, 2)
  taxRate       Decimal         @default(0.1) @db.Decimal(5, 4) // e.g., 0.1 = 10%
  taxAmount     Decimal         @db.Decimal(12, 2)
  total         Decimal         @db.Decimal(12, 2)
  currency      String          @default("USD")
  
  // Notes
  notes         String?
  
  // Relations
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProfileId String      
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Restrict)
  clientId      String          
  client        Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  lineItemAssignments InvoiceLineItemAssignment[]
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  @@index([userId])
  @@index([businessProfileId])
  @@index([clientId])
}

model InvoiceLineItem {
  id          String    @id @default(cuid())
  userId      String    
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal   @db.Decimal(10, 2)
  rate        Decimal   @db.Decimal(12, 2) 
  amount      Decimal   @db.Decimal(12, 2)
  
  invoiceAssignments InvoiceLineItemAssignment[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
}

model InvoiceLineItemAssignment {
  id              String          @id @default(cuid())
  invoiceId       String
  invoice         Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineItemId       String
  lineItem        InvoiceLineItem @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  
  order           Int             @default(0)
  
  createdAt       DateTime        @default(now())
  
  @@unique([invoiceId, lineItemId])
  @@index([invoiceId])
  @@index([lineItemId])
}